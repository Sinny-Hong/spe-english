  <!-- JavaScript 輔助作答與慢速發音邏輯 -->
  <script>
    let showAnswersState = false;

    // 清晰慢速發音輔助（0.8 語速專為特教需求、初學者設計）
    function speakWord(word) {
      if ('speechSynthesis' in window) {
        window.speechSynthesis.cancel();
        const utterance = new SpeechSynthesisUtterance(word);
        utterance.lang = 'en-US';
        utterance.rate = 0.8; 
        window.speechSynthesis.speak(utterance);
      } else {
        console.log("當前瀏覽器不支援 TTS 語音播放功能。");
      }
    }

    // 線上核對/切換隱藏答案功能
    function toggleAnswers() {
      showAnswersState = !showAnswersState;
      const inputs = document.querySelectorAll('.answer-input');
      inputs.forEach(input => {
        const correctAnswer = input.getAttribute('data-answer');
        if (showAnswersState) {
          input.value = correctAnswer;
          input.classList.add('bg-blue-100', 'text-blue-800', 'border-blue-500');
        } else {
          input.value = '';
          input.classList.remove('bg-blue-100', 'text-blue-800', 'border-blue-500');
        }
      });
    }

    // 重設清除所有作答輸入
    function clearAnswers() {
      const inputs = document.querySelectorAll('.answer-input');
      inputs.forEach(input => {
        input.value = '';
        input.classList.remove('bg-blue-100', 'text-blue-800', 'border-blue-500');
      });
      showAnswersState = false;
    }

    // 作答限制與大寫自動轉換
    const inputsArray = Array.from(document.querySelectorAll('.answer-input'));
    inputsArray.forEach((input, index) => {
      input.addEventListener('input', function() {
        this.value = this.value.toUpperCase();
        if (!/^[A-C]$/.test(this.value)) {
          this.value = '';
        }

        // 輸入完成後自動跳到下一題
        if (this.value !== '') {
          if (index < inputsArray.length - 1) {
            inputsArray[index + 1].focus();
          }
        }
      });

      // 支援退格鍵刪除並返回上一題
      input.addEventListener('keydown', function(e) {
        if (e.key === 'Backspace' && this.value === '' && index > 0) {
          inputsArray[index - 1].focus();
        }
      });
    });
  </script>
