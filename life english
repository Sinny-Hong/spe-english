        let currentPage = 1;
        const perPage = 10;
        let answers = {};
        let submitted = false;

        function setup() {
            createNav();
            render(1);
            generateQR();
        }

        function createNav() {
            const container = document.getElementById('nav-container');
            container.innerHTML = '';
            for (let i = 1; i <= 10; i++) {
                const start = (i - 1) * 10 + 1;
                const end = i * 10;
                const btn = document.createElement('button');
                btn.className = `nav-btn px-5 py-2.5 rounded-xl text-sm font-medium`;
                btn.id = `nav-${i}`;
                btn.innerText = `${start}-${end}`;
                btn.onclick = () => render(i);
                container.appendChild(btn);
            }
        }

        function render(page) {
            currentPage = page;
            document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
            const activeBtn = document.getElementById(`nav-${page}`);
            if (activeBtn) activeBtn.classList.add('active');

            const wrapper = document.getElementById('quiz-wrapper');
            wrapper.innerHTML = '';

            const start = (page - 1) * perPage;
            const currentItems = questionBank.slice(start, start + perPage);

            currentItems.forEach(item => {
                const card = document.createElement('div');
                card.className = `question-card p-10 rounded-3xl border ${submitted ? 'submitted' : ''}`;
                
                let opts = '';
                const labels = ["A", "B", "C", "D"];
                item.options.forEach((text, idx) => {
                    const isPicked = answers[item.id] === idx;
                    let style = "border-stone-50";
                    let textStyle = "text-stone-600";
                    let iconStyle = "text-stone-300";
                    
                    if (submitted) {
                        if (idx === item.ans) {
                            style = "bg-emerald-50 border-emerald-500 text-emerald-900 font-bold submitted-ui";
                            textStyle = "text-emerald-900";
                            iconStyle = "text-emerald-500";
                        } else if (isPicked) {
                            style = "bg-rose-50 border-rose-400 text-rose-900 submitted-ui";
                            textStyle = "text-rose-900";
                            iconStyle = "text-rose-400";
                        } else {
                            style = "opacity-40 grayscale border-transparent submitted-ui";
                        }
                    }

                    opts += `
                        <label class="option-label block mb-3 cursor-pointer ${submitted ? 'disabled' : ''}">
                            <input type="radio" name="q${item.id}" value="${idx}" 
                                ${isPicked ? 'checked' : ''} 
                                ${submitted ? 'disabled' : ''}
                                onchange="record(${item.id}, ${idx})"
                                class="option-input hidden">
                            <div class="option-ui flex items-center p-4 border rounded-2xl transition-all ${style}">
                                <span class="text-xs font-black w-8 ${iconStyle} uppercase">${labels[idx]}</span>
                                <span class="option-text text-[15px] flex-1 ${textStyle}">${text}</span>
                            </div>
                        </label>
                    `;
                });

                // 強制控制詳解區塊的顯示 (不依賴 CSS 選擇器)
                const explanationDisplay = submitted ? 'block' : 'none';

                card.innerHTML = `
                    <h3 class="text-xl font-medium text-stone-800 mb-10 leading-relaxed">${item.id}. ${item.q}</h3>
                    <div class="space-y-1">${opts}</div>
                    <div class="explanation-box mt-10 p-8 bg-stone-50 rounded-2xl text-sm" style="display: ${explanationDisplay}">
                        <p class="text-stone-400 font-black mb-3 tracking-widest uppercase text-[10px]">Feedback & Analysis</p>
                        <p class="text-stone-600 leading-loose">${item.explain}</p>
                    </div>
                `;
                wrapper.appendChild(card);
            });

            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function record(id, val) {
            answers[id] = val;
        }

        function handlePreSubmit() {
            const count = Object.keys(answers).length;
            if (count < 100) {
                if (!confirm(`尚有 ${100 - count} 題未作答，確定要送出評估嗎？`)) return;
            }
            process();
        }

        function process() {
            submitted = true;
            let score = 0;
            questionBank.forEach(q => {
                if (answers[q.id] === q.ans) score++;
            });

            document.getElementById('btn-submit').classList.add('hidden');
            document.getElementById('result-display').classList.remove('hidden');
            document.getElementById('score-text').innerText = `${score} / 100`;

            let msg = "已完成評測。建議查閱每一頁的正確答案與詳細解析。";
            if (score >= 90) msg = "卓越！您的基礎生活英文掌握得非常出色。" + msg;
            else if (score >= 70) msg = "表現良好。請查閱錯題解析，持續精進。" + msg;
            else if (score >= 60) msg = "恭喜及格！建議多練習生活中常見的英文標示。" + msg;
            else msg = "還有進步空間。請仔細閱讀解析並反覆挑戰。" + msg;
            
            document.getElementById('comment-text').innerText = msg;

            render(1);
            document.getElementById('result-display').scrollIntoView({ behavior: 'smooth' });
        }

        function generateQR() {
            const url = window.location.href;
            document.getElementById('qr-image').src = `https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=${encodeURIComponent(url)}&color=434a54`;
        }

        document.addEventListener('DOMContentLoaded', setup);
    </script>
